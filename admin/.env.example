# =============================================================================
# Engraced Smile Dispatch — Production Environment Variables
# Copy this to .env and fill in real values before deployment
# =============================================================================

# ─── Firebase (Required) ───────────────────────────────────────────────────
VITE_FIREBASE_API_KEY=YOUR_FIREBASE_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=YOUR_PROJECT.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=YOUR_FIREBASE_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=YOUR_PROJECT.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=YOUR_SENDER_ID
VITE_FIREBASE_APP_ID=YOUR_APP_ID

# Firebase Admin Service Account (base64-encoded JSON key file)
# Generate: Go to Firebase Console → Project Settings → Service Accounts → Generate New Private Key
# Then encode: base64 -w0 path/to/serviceAccountKey.json
FIREBASE_SERVICE_ACCOUNT_BASE64=YOUR_BASE64_ENCODED_SERVICE_ACCOUNT_JSON

# ─── Paystack (Required for wallet funding) ────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
# Paystack public key is used by the mobile apps
VITE_PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx

# ─── Firebase Cloud Messaging (Required for push notifications) ────────────
# Get from: Firebase Console → Project Settings → Cloud Messaging → Server key
FCM_SERVER_KEY=AAAAxxxxxxxxxxxxxxxxxxxx:APA91bxxxxxxxxx

# ─── Mapbox (Required for maps & tracking) ─────────────────────────────────
MAPBOX_ACCESS_TOKEN=pk.eyJ1xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── App URLs ──────────────────────────────────────────────────────────────
VITE_ADMIN_URL=https://admin.engraceddispatch.com
VITE_CUSTOMER_APP_URL=https://play.google.com/store/apps/details?id=com.aistudio.engraceddispatch.kxmpzq
VITE_RIDER_APP_URL=https://play.google.com/store/apps/details?id=com.aistudio.engraceddispatch.kxmpzq.rider

# ─── Environment ───────────────────────────────────────────────────────────
# Set to "production" for live, "development" for testing
VITE_APP_ENV=development
