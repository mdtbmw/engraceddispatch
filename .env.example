# ENGRACED DISPATCH - Environment Template
# Copy this file to .env and fill in your values.
# Used by: Android app (Secrets Gradle Plugin -> BuildConfig.*)
#           Next.js admin (NEXT_PUBLIC_* inlined into client bundle)

# --- Firebase Core ---
FIREBASE_API_KEY=
FIREBASE_APPLICATION_ID=
FIREBASE_PROJECT_ID=
FIREBASE_DATABASE_URL=
FIREBASE_GCM_SENDER_ID=

# --- Android-only (baked into APK via BuildConfig) ---
MAPBOX_ACCESS_TOKEN=
GEMINI_API_KEY=
GOOGLE_WEB_CLIENT_ID=
PAYSTACK_PUBLIC_KEY=

# --- Next.js Admin (NEXT_PUBLIC_* exposed to browser) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_APPLICATION_ID=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_GCM_SENDER_ID=
NEXT_PUBLIC_GOOGLE_WEB_CLIENT_ID=
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
