rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // =========================================================
    // HELPERS
    // =========================================================

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() && (
        request.auth.token.role == 'admin' ||
        request.auth.token.role == 'super_admin' ||
        request.auth.token.admin == true ||
        (request.auth.token.role == null && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin'
        ))
      );
    }

    function isDispatcher() {
      return isAdmin() || (isAuth() && (
        request.auth.token.role == 'dispatcher' ||
        request.auth.token.dispatcher == true ||
        (request.auth.token.role == null && (
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'dispatcher'
        ))
      ));
    }

    function isOwner(userId) {
      return isAuth() && request.auth.uid == userId;
    }

    // Validate contact/subscriber data to prevent abuse
    function isValidContact() {
      return request.resource.data.keys().hasAll(['name', 'email', 'message'])
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.message is string
        && request.resource.data.name.size() > 0
        && request.resource.data.email.size() > 0
        && request.resource.data.message.size() > 0;
    }

    function isValidSubscriber() {
      return request.resource.data.keys().hasAll(['email'])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 0;
    }

    // =========================================================
    // USER PROFILES
    // =========================================================

    function isAdminRole(role) {
      return role == 'admin' || role == 'super_admin';
    }

    function notElevatingToAdmin() {
      return isAdmin() || !request.resource.data.keys().hasAny(['role']) || (request.resource.data.role != 'admin' && request.resource.data.role != 'super_admin');
    }

    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isOwner(userId) && notElevatingToAdmin();
      allow update: if (isOwner(userId) && notElevatingToAdmin() && (
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['walletBalance', 'loyaltyPoints']) || (
          !('walletBalance' in resource.data) &&
          request.resource.data.walletBalance == 500.0 &&
          !('loyaltyPoints' in resource.data) &&
          request.resource.data.loyaltyPoints == 10
        )
      )) || isAdmin();
      allow delete: if isAdmin();

      match /notifications/{notifId} {
        allow read: if isOwner(userId);
        allow create: if isAdmin();
        allow update: if isOwner(userId) || isAdmin();
        allow delete: if isAdmin();
      }
    }

    // =========================================================
    // DELIVERIES / SHIPMENTS
    // =========================================================

    match /deliveries/{deliveryId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update: if isDispatcher() || (isAuth() && (
        resource.data.riderId == request.auth.uid ||
        resource.data.courierId == request.auth.uid ||
        request.resource.data.riderId == request.auth.uid ||
        request.resource.data.courierId == request.auth.uid
      ));
      allow delete: if isAdmin();
    }

    // =========================================================
    // PUBLIC-FACING CMS (read by anyone, written by admin)
    // =========================================================

    match /banners/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promotions/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /appContent/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /site_content/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /system_config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // =========================================================
    // CMS COLLECTIONS (service cards, team, testimonials, blog, portfolio)
    // =========================================================

    match /cms_services/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cms_team/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cms_testimonials/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cms_blog/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cms_portfolio/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // =========================================================
    // REFERRALS
    // =========================================================

    match /referrals/{docId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if isAdmin();
    }

    // =========================================================
    // PENDING PAYMENTS (Secure wallet verification)
    // =========================================================

    match /pending_payments/{paymentId} {
      allow read: if isAuth() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid && request.resource.data.status == 'pending';
      allow update, delete: if isAdmin();
    }

    // =========================================================
    // NOTIFICATIONS
    // =========================================================

    match /notifications/{docId} {
      allow read: if isAuth();
      allow create: if isDispatcher();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // =========================================================
    // AUDIT LOGS
    // =========================================================

    match /audit_logs/{docId} {
      allow read: if isAdmin();
      allow create: if isDispatcher();
      allow update, delete: if isAdmin();
    }

    // =========================================================
    // PUBLIC FORM SUBMISSIONS (no auth required, validated)
    // =========================================================

    match /contacts/{docId} {
      allow read: if isAdmin();
      allow create: if isValidContact();
      allow update, delete: if isAdmin();
    }

    match /subscribers/{docId} {
      allow read: if isAdmin();
      allow create: if isValidSubscriber();
      allow update, delete: if isAdmin();
    }
  }
}
