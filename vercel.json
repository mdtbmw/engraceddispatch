{
  "buildCommand": "cd admin && npm run build",
  "outputDirectory": "admin/dist",
  "installCommand": "cd admin && npm install",
  "framework": "vite",
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
