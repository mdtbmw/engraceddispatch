# Engraced Smiles Dispatch - Environment Variables
# Copy this file to .env.local and fill in values

# Site URL (used for sitemaps, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://www.engracedsmilesdispatch.com

# Google Analytics (optional)
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Contact email
NEXT_PUBLIC_CONTACT_EMAIL=info@engracedsmilesdispatch.com

# Phone number
NEXT_PUBLIC_PHONE=+2348000000000
